{
	"name": "obsidian-embed-eml",
	"version": "1.0.1",
	"description": "Embed .eml email files directly in your Obsidian notes.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"eml",
		"email",
		"embed"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"esbuild": "^0.28.1",
		"obsidian": "latest",
		"typescript": "^5.4.5"
	},
	"dependencies": {
		"postal-mime": "^2.2.5"
	},
	"allowScripts": {
		"esbuild@0.28.1": true
	}
}
