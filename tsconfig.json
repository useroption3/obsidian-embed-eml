{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2018",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ES5",
			"ES6",
			"ES7",
			"ES2018",
			"ES2019"
		]
	},
	"include": [
		"src/**/*.ts"
	]
}
